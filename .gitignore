# ============================================================
# Zela Varginha — .gitignore raiz
# Tudo aqui NUNCA deve ser commitado nem publicado.
# ============================================================

# ---- Segredos / Credenciais ----
.betha-token*.json
.env
.env.*
*.pem
*.key
gemini_key.php
*_key.php
gemini_key.txt
gemini_key.local
*.local
private/
secrets/

# ---- Cache da IA (Gemini) e do Diário — regeneráveis ----
painel-cidadao/data/cache_ia/
painel-cidadao/data/cache_diario/
painel-cidadao/data/_log_*.txt
painel-cidadao/_teste_*.py

# ---- Logs e diagnóstico ----
*.log
debug.log
runtime/
private/logs/

# ---- Cache Python ----
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# ---- Node / npm ----
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
.pnpm-debug.log

# ---- Playwright / browsers ----
.playwright-mcp/
playwright-report/
test-results/
blob-report/
playwright/.cache/

# ---- Backups / temporários ----
*.bak
*.backup
*.orig
*.tmp
old_*.html
temp_*.html
*~
.DS_Store
Thumbs.db

# ---- Builds e bundles ----
dashboard/dist/
dashboard/build/
dashboard/.next/
dashboard/.vite/
dist/
build/

# ---- IDE ----
.vscode/
.idea/
*.iml
*.swp
*.swo

# ---- Opensquad — config + sessões privadas ----
_opensquad/_browser_profile/
_opensquad/_investigations/

# ---- WhatsApp bridge — credenciais de sessão (chaves Signal) — NUNCA versionar ----
# Quem tiver esses arquivos controla o WhatsApp conectado.
painel-cidadao/whatsapp-bridge/auth_info/

# ---- Fonte bruta das emendas (132 MB de PDFs) — NUNCA versionar ----
# Pasta de trabalho com os PDFs originais das emendas municipais. O portal
# publicado vive em painel-cidadao/emendas/ (leve). Esta é só a fonte bruta.
Publicidade Emendas/

# ---- Dados brutos grandes (regeneráveis pelo coletor) ----
# JSONs em painel-cidadao/data/ (raiz) são staging do coletor e duplicam
# painel-cidadao/data/chunks/ (única pasta publicada no deploy). Não versionar
# a raiz — só os chunks e o manifest.json.
painel-cidadao/data/*.json
!painel-cidadao/data/manifest.json

# data.js (monolito ~6,6MB, fallback file://) é gerado pelo coletor.py.
# Regenerável e copiado ao empacotar — não versionar (evita diff diário de MBs).
painel-cidadao/data.js

# ---- Screenshots de QA (não publicáveis em prod) ----
*.png
__fc.png
!painel-cidadao/favicon.svg
!painel-cidadao/assets/**/*.png

# ---- Scripts temporários de fix ----
_fix_*.py
_check*.py
_find_*.py

# ---- Bundles de deploy (regeneráveis pelo empacotador) ----
*.zip

# ---- Helpers de dev/QA locais (não publicáveis) ----
take_screenshot.js
painel-cidadao/encode_deploy.js

# ---- Config local do Claude Code ----
.claude/

# ---- Antigravity — brain/scratch interno (pode conter senhas hardcoded) ----
.gemini/
.antigravity/

# Local Netlify folder
.netlify

# ---- WhatsApp bridge — chave da API (fora do git) ----
painel-cidadao/whatsapp-bridge/.apikey
