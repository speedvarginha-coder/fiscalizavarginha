# Fiscaliza Varginha — proteção de arquivos sensíveis
# Permite apenas os dados públicos necessários ao navegador.

Options -Indexes
RewriteEngine On

# Scripts e arquivos locais nunca devem ser servidos.
<FilesMatch "\.(log|py|pyc|bat|txt)$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Tokens Betha, caso apareçam por engano dentro da pasta pública.
<FilesMatch "^\.betha-token.*\.json$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>

# Bloqueia dotfiles e cache Python.
RewriteRule ^\. - [F,L]
RewriteRule ^__pycache__/ - [F,L]

# Bloqueia JSONs intermediários em /data/, mas libera:
# - /data/manifest.json
# - /data/chunks/*.json
# - /data/snapshots/*.json
RewriteRule ^data/(?!manifest\.json$|chunks/[^/]+\.json$|snapshots/[^/]+\.json$) - [F,L]
